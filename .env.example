# ====================================================================
# CẤU HÌNH MÔI TRƯỜNG - ZERO-COST STACK (TEMPLATE)
# ====================================================================
# Copy file này thành .env và điền API keys
# Tất cả services đều MIỄN PHÍ!
# ====================================================================
DEMO_MODE=true

# --- Gemini 2.5 Flash ---
# Đăng ký free: https://aistudio.google.com/apikey
# Mỗi agent dùng key riêng để tránh hết quota khi demo
# Key riêng trống → dùng GEMINI_API_KEY chung
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash-preview-05-20
GEMINI_API_KEY_PLANNER=
GEMINI_API_KEY_EXECUTOR=
# Pool keys cho Executor parallel (comma-separated, tối đa 5 keys)
# Ví dụ: key1,key2,key3,key4,key5
# Có bao nhiêu task thì dùng bấy nhiêu key song song
GEMINI_API_KEY_EXECUTOR_POOL=
GEMINI_API_KEY_DETECTIVE=
GEMINI_API_KEY_VISION=
GEMINI_API_KEY_REPORT=

# --- Neo4j AuraDB (thay Amazon Neptune) ---
# Đăng ký free: https://neo4j.com/cloud/aura-free/
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- ChromaDB Cloud (thay Amazon OpenSearch) ---
# Đăng ký free: https://trychroma.com
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_COLLECTION_NAME=fraud_knowledge_base

# --- Redis Cloud (thay Amazon ElastiCache) ---
# Phase 1: whitelist, blacklist, risk scores, velocity tracking
# Đăng ký free: https://redis.com/try-free/
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# --- MongoDB Atlas (thay Amazon DynamoDB) ---
# Đăng ký free: https://www.mongodb.com/atlas/database
MONGODB_URI=
MONGODB_DB_NAME=fraud_detection

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- CORS (Frontend URL for production) ---
# Set this to your Vercel frontend URL for production deployment
# Example: https://your-app.vercel.app
FRONTEND_URL=
